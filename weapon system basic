        "from abc import ABC , abstractmethod\n",
        "\n",
        "class weapon(ABC):\n",
        "  @abstractmethod\n",
        "  def attack (self):\n",
        "          pass\n",
        "class swoard(weapon):\n",
        "  def attack(self):\n",
        "    print(\"swosh..swosh\")\n",
        "class gun (weapon):\n",
        "  def attack(self):\n",
        "    print(\"trrrrrrrr\")\n",
        "class bow(weapon):\n",
        "  def attack(self):\n",
        "    print(\"thiwp\")\n",
        "class magicwand(weapon):\n",
        "  def attack(self):\n",
        "    print(\"expecto patronum\")\n",
        "\n",
        "class player():\n",
        "  def __init__(self,weapon):\n",
        "    self.weapon = weapon\n",
        "  def use_weapon(self):\n",
        "    self.weapon.attack()\n",
        "\n",
        "\n",
        "\n",
