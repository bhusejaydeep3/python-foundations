from abc import ABC, abstractmethod
import numpy as np

class Account(ABC):
    def __init__(self, owner, balance=0):
        self.owner = owner
        self.__balance = balance
        self.__transactions = np.array([])  # lives HERE in base class

    def get_balance(self):
        return self.__balance

    def get_transactions(self):
        return self.__transactions

    def deposit(self, amount):
        self.__balance += amount
        self.__transactions = np.append(self.__transactions, amount)  # append here

    def withdraw(self, amount):
        if self.__balance < amount:
            print("Not enough balance")
        else:
            self.__balance -= amount
            self.__transactions = np.append(self.__transactions, -amount)  # negative = withdrawal
            print(f"Amount withdrawn: {amount}")

    @abstractmethod
    def calculate_interest(self):
        pass

    def transaction_summary(self):
        t = self.__transactions
        if len(t) == 0:
            print("No transactions yet")
            return
        print(f"Total transactions : {len(t)}")
        print(f"Total deposited    : {t[t > 0].sum()}")
        print(f"Total withdrawn    : {abs(t[t < 0].sum())}")
        print(f"Average transaction: {np.mean(np.abs(t)):.2f}")

    def show_balance(self):
        print(f"Balance: {self.__balance}")


class SavingsAccount(Account):
    def __init__(self, owner, balance=0, rate=0.04):
        super().__init__(owner, balance)
        self.rate = rate

    def deposit(self, amount):
        super().deposit(amount)          # base handles balance + transactions
        print(f"Deposited {amount} to savings")

    def withdraw(self, amount):
        super().withdraw(amount)         # base handles balance + transactions

    def calculate_interest(self):
        return self.get_balance() * self.rate   # getter, no mangling

    def show_balance(self):
        print(f"Savings balance: {self.get_balance()}")


class CurrentAccount(Account):
    def __init__(self, owner, balance=0):
        super().__init__(owner, balance)

    def deposit(self, amount):
        super().deposit(amount)
        print(f"Deposited {amount} to current account")

    def withdraw(self, amount):
        super().withdraw(amount)

    def calculate_interest(self):
        return 0

    def show_balance(self):
        print(f"Current account balance: {self.get_balance()}")
